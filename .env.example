# Environment file for Docker deployment
# Copy this to .env and fill in your values

# Required: Your Discord bot token
DISCORD_TOKEN=your_bot_token_here

# Required: Bot owner user IDs (comma-separated)
OWNERS=123456789012345678,987654321098765432
# Optional: Lavalink node configuration
# Run a Lavalink server and set these to connect to it
LAVALINK_NODE_NAME=main
LAVALINK_HOST=localhost:2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Optional: Discord WebUI dashboard settings
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback
API_PORT=4000
DASHBOARD_ORIGIN=*
SQLITE_PATH=
