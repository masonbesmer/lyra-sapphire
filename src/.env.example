# Tokens
DISCORD_TOKEN=your_discord_bot_token_here
OWNERS=123456789012345678,987654321098765432

# Optional path to the SQLite database. Defaults to ./data/word_triggers.db
SQLITE_PATH=

# Optional development guild ID for command registration. Defaults to '925192180480491540'
BULK_OVERWRITE_GUILD_IDS=

# Environment
NODE_ENV=development

# Lavalink Configuration (required for music system)
# See LAVALINK.md for detailed setup instructions
LAVALINK_NODE_NAME=main
LAVALINK_HOST=localhost:2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# WebUI Dashboard (optional — required to enable the web dashboard)
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_CLIENT_SECRET=your_oauth2_secret_here
OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback
API_PORT=4000
DASHBOARD_ORIGIN=*