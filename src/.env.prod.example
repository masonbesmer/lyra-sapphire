# Production Environment Configuration
# Copy this to .env.prod and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# Discord Bot Configuration (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════

DISCORD_TOKEN=your_production_bot_token_here
OWNERS=123456789012345678,987654321098765432

# ═══════════════════════════════════════════════════════════════════════════
# Lavalink Configuration (REQUIRED for Music System)
# ═══════════════════════════════════════════════════════════════════════════

LAVALINK_NODE_NAME=main
LAVALINK_HOST=lavalink:2333
LAVALINK_PASSWORD=your_secure_lavalink_password_here
LAVALINK_SECURE=false

# Optional Shoukaku tuning (milliseconds for interval/timeout)
# LAVALINK_RECONNECT_TRIES=5
# LAVALINK_RECONNECT_INTERVAL=3000
# LAVALINK_REST_TIMEOUT=30000

# For external Lavalink server with SSL:
# LAVALINK_HOST=lavalink.yourdomain.com:443
# LAVALINK_SECURE=true

# ═══════════════════════════════════════════════════════════════════════════
# Database Configuration (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════

SQLITE_PATH=/app/data/word_triggers.db

# ═══════════════════════════════════════════════════════════════════════════
# Web Dashboard (OPTIONAL - Only if using the web UI)
# ═══════════════════════════════════════════════════════════════════════════

# DISCORD_CLIENT_ID=your_application_id_here
# DISCORD_CLIENT_SECRET=your_oauth2_secret_here
# OAUTH_REDIRECT_URI=https://yourdomain.com/oauth/callback
# API_PORT=4000
# DASHBOARD_ORIGIN=https://yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════
# Environment
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=production
